{
  "extends": "_bases/supermicro_ipmi",
  "metadata": {
    "model_family": ["X10SRL-F", "X10SRA-F", "X10DRi", "X10SRi-F"],
    "author": "Pankha Official",
    "description": "Supermicro X10/X11 series. Dual-zone fan control via 0x30 0x70 0x66 sequence. Uses decimal_hex translation (percentage maps directly to hex). Includes read_speed for Tier 2 fan speed resolution."
  },
  "protocols": {
    "ipmi": {
      "fan_zones": [
        {
          "id": "cpu_zone",
          "name": "Zone 0 - CPU Fans",
          "members": ["FAN1", "FAN2", "FAN3", "FAN4"],
          "speed_translation": {
            "type": "decimal_hex",
            "input_min": 0,
            "input_max": 100,
            "output_min": 0,
            "output_max": 100
          },
          "commands": {
            "set_speed": {
              "type": "ipmitool_raw",
              "bytes": "0x30 0x70 0x66 0x01 0x00 {{SPEED_HEX}}"
            },
            "read_speed": {
              "type": "ipmitool_raw",
              "bytes": "0x30 0x70 0x66 0x00 0x00"
            }
          }
        },
        {
          "id": "peripheral_zone",
          "name": "Zone 1 - Peripheral Fans",
          "members": ["FANA", "FANB"],
          "speed_translation": {
            "type": "decimal_hex",
            "input_min": 0,
            "input_max": 100,
            "output_min": 0,
            "output_max": 100
          },
          "commands": {
            "set_speed": {
              "type": "ipmitool_raw",
              "bytes": "0x30 0x70 0x66 0x01 0x01 {{SPEED_HEX}}"
            },
            "read_speed": {
              "type": "ipmitool_raw",
              "bytes": "0x30 0x70 0x66 0x00 0x01"
            }
          }
        }
      ]
    }
  }
}
